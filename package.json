{
  "name": "storyline-cli",
  "version": "1.1.6",
  "description": "Storyline — a planning and writing environment for novelists, built around the Save the Cat story structure, with AI co-writing support powered by Claude.",
  "type": "module",
  "bin": {
    "storyline": "./bin/storyline.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "skill/",
    "skill-follow-up/",
    "templates/",
    "vscode-extension/storyline-vscode-*.vsix",
    ".env.example",
    "CLAUDE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DarrenJCoxon/storyline.git"
  },
  "homepage": "https://github.com/DarrenJCoxon/storyline#readme",
  "bugs": "https://github.com/DarrenJCoxon/storyline/issues",
  "keywords": [
    "novel",
    "writing",
    "save-the-cat",
    "story-planning",
    "claude",
    "vscode",
    "epub"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/storyline.js",
    "test": "vitest run",
    "prepublishOnly": "npm test && node -e \"if(!require('fs').readdirSync('vscode-extension').some(f=>/^storyline-vscode-.+\\.vsix$/.test(f))){console.error('Missing bundled .vsix — run: cd vscode-extension && npm run package');process.exit(1)}\""
  },
  "dependencies": {
    "@lesjoursfr/html-to-epub": "^3.1.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.16",
    "markdown-it": "^14.1.1",
    "ora": "^5.4.1",
    "pagedjs": "^0.4.3",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "vitest": "^1.4.0"
  }
}

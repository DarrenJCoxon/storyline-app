{
  "name": "storyline-vsc",
  "version": "1.3.6",
  "description": "Storyline — a planning and writing environment for novelists and non-fiction authors, built around Save the Cat story structure and a three-pipeline non-fiction harness, with AI co-planning support powered by Claude.",
  "type": "module",
  "bin": {
    "storyline": "./bin/storyline.js"
  },
  "files": [
    "agents/",
    "bin/",
    "lib/",
    "scripts/",
    "skill/",
    "skill-follow-up/",
    "skill-critique/",
    "skill-nf/",
    "templates/",
    "vscode-extension/storyline-vscode-*.vsix",
    ".env.example",
    "CLAUDE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DarrenJCoxon/storyline.git"
  },
  "homepage": "https://github.com/DarrenJCoxon/storyline#readme",
  "bugs": "https://github.com/DarrenJCoxon/storyline/issues",
  "keywords": [
    "novel",
    "writing",
    "save-the-cat",
    "story-planning",
    "non-fiction",
    "book-planning",
    "claude",
    "vscode",
    "epub"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/storyline.js",
    "test": "vitest run",
    "verify-readme:pre": "node scripts/verify-readme-publish.js pre",
    "verify-readme:post": "node scripts/verify-readme-publish.js post",
    "prepublishOnly": "npm test && node -e \"if(!require('fs').readdirSync('vscode-extension').some(f=>/^storyline-vscode-.+\\.vsix$/.test(f))){console.error('Missing bundled .vsix — run: cd vscode-extension && npm run package');process.exit(1)}\" && npm run verify-readme:pre",
    "postpublish": "npm run verify-readme:post",
    "ship": "npm run ship:extension && npm run ship:tauri",
    "ship:extension": "cd extension && npm run package",
    "ship:tauri": "cd installer && npm run tauri build"
  },
  "dependencies": {
    "@lesjoursfr/html-to-epub": "^3.1.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.16",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "odd-flow": "^1.2.5",
    "ora": "^5.4.1",
    "pagedjs": "^0.4.3",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.42.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@fontsource/crimson-pro": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "vitest": "^1.4.0"
  }
}

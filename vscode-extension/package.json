{
  "name": "novel-writer-vscode",
  "displayName": "Novel Writer",
  "description": "Rich-text writing surface for novel projects using the Novel Writer planning harness. Files stay markdown on disk.",
  "version": "0.14.2",
  "publisher": "darrenjcoxon",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.novel-writer/state.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "novelWriter.editor",
        "displayName": "Novel Writer Rich Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "novelWriter.hello",
        "title": "Novel Writer: Hello (scaffold check)"
      },
      {
        "command": "novelWriter.openEditor",
        "title": "Novel Writer: Open in Rich Editor"
      },
      {
        "command": "novelWriter.showWordCountBreakdown",
        "title": "Novel Writer: Show Word Count Breakdown"
      },
      {
        "command": "novelWriter.compileEpub",
        "title": "Novel Writer: Compile to EPUB",
        "icon": "$(book)"
      },
      {
        "command": "novelWriter.compilePrintPdf",
        "title": "Novel Writer: Compile to Print PDF",
        "icon": "$(file-pdf)"
      },
      {
        "command": "novelWriter.openPreview",
        "title": "Novel Writer: Open Preview",
        "icon": "$(preview)"
      },
      {
        "command": "novelWriter.openLivePreview",
        "title": "Novel Writer: Open Live Chapter Preview",
        "icon": "$(eye)"
      },
      {
        "command": "novelWriter.editBookInfo",
        "title": "Novel Writer: Edit Book Info",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "novelWriter.openEditor",
          "when": "resourceExtname == .md",
          "group": "navigation@99"
        }
      ],
      "editor/title/context": [
        {
          "command": "novelWriter.openEditor",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run copy-assets && npm run compile:host && npm run compile:webview",
    "copy-assets": "node scripts/copy-theme-assets.mjs",
    "compile:host": "tsc -p ./",
    "compile:webview": "node esbuild.config.mjs",
    "watch": "npm-run-all --parallel watch:host watch:webview",
    "watch:host": "tsc -watch -p ./",
    "watch:webview": "node esbuild.config.mjs --watch",
    "package": "npm run compile && vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/pm": "^2.1.0",
    "@tiptap/react": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}

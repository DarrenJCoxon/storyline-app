{
  "name": "storyline-vscode",
  "displayName": "Storyline",
  "description": "Rich-text writing surface for novel projects using the Storyline planning harness. Files stay markdown on disk.",
  "version": "0.33.1",
  "publisher": "darrenjcoxon",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.storyline/state.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "storyline.hello",
        "title": "Storyline: Hello (scaffold check)"
      },
      {
        "command": "storyline.openEditor",
        "title": "Storyline: Open in Rich Editor"
      },
      {
        "command": "storyline.openToSide",
        "title": "Storyline: Open to the Side",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "storyline.showWordCountBreakdown",
        "title": "Storyline: Show Word Count Breakdown"
      },
      {
        "command": "storyline.compileEpub",
        "title": "Storyline: Compile to EPUB",
        "icon": "$(book)"
      },
      {
        "command": "storyline.compilePrintPdf",
        "title": "Storyline: Compile to Print PDF",
        "icon": "$(file-pdf)"
      },
      {
        "command": "storyline.openPreview",
        "title": "Storyline: Open Preview",
        "icon": "$(preview)"
      },
      {
        "command": "storyline.openLivePreview",
        "title": "Storyline: Open Live Chapter Preview",
        "icon": "$(eye)"
      },
      {
        "command": "storyline.editBookInfo",
        "title": "Storyline: Edit Book Info",
        "icon": "$(info)"
      },
      {
        "command": "storyline.setBackupFolder",
        "title": "Storyline: Set Backup Folder"
      },
      {
        "command": "storyline.openBackupFolder",
        "title": "Storyline: Open Backup Folder"
      },
      {
        "command": "storyline.showBackupLog",
        "title": "Storyline: Show Backup Log"
      },
      {
        "command": "storyline.toggleComposeMode",
        "title": "Storyline: Toggle Compose Mode"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "storyline.hello", "when": "storyline.active" },
        { "command": "storyline.openEditor", "when": "storyline.active" },
        { "command": "storyline.openToSide", "when": "storyline.active" },
        { "command": "storyline.showWordCountBreakdown", "when": "storyline.active" },
        { "command": "storyline.compileEpub", "when": "storyline.active" },
        { "command": "storyline.compilePrintPdf", "when": "storyline.active" },
        { "command": "storyline.openPreview", "when": "storyline.active" },
        { "command": "storyline.openLivePreview", "when": "storyline.active" },
        { "command": "storyline.editBookInfo", "when": "storyline.active" },
        { "command": "storyline.setBackupFolder", "when": "storyline.active" },
        { "command": "storyline.openBackupFolder", "when": "storyline.active" },
        { "command": "storyline.showBackupLog", "when": "storyline.active" },
        { "command": "storyline.toggleComposeMode", "when": "storyline.active" }
      ],
      "explorer/context": [
        {
          "command": "storyline.openEditor",
          "when": "storyline.active && resourceExtname == .md",
          "group": "navigation@99"
        },
        {
          "command": "storyline.openToSide",
          "when": "storyline.active && resourceExtname == .md",
          "group": "navigation@100"
        }
      ],
      "editor/title/context": [
        {
          "command": "storyline.openEditor",
          "when": "storyline.active && resourceExtname == .md",
          "group": "1_modification"
        },
        {
          "command": "storyline.openToSide",
          "when": "storyline.active && resourceExtname == .md",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "storyline.openToSide",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "storyline.active && filesExplorerFocus && resourceExtname == .md"
      },
      {
        "command": "storyline.toggleComposeMode",
        "key": "ctrl+k ctrl+m",
        "mac": "cmd+k cmd+m",
        "when": "storyline.active"
      }
    ]
  },
  "scripts": {
    "compile": "npm run copy-assets && npm run compile:host && npm run compile:webview",
    "copy-assets": "node scripts/copy-theme-assets.mjs",
    "compile:host": "tsc -p ./",
    "compile:webview": "node esbuild.config.mjs",
    "watch": "npm-run-all --parallel watch:host watch:webview",
    "watch:host": "tsc -watch -p ./",
    "watch:webview": "node esbuild.config.mjs --watch",
    "package": "npm run compile && vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/pm": "^2.1.0",
    "@tiptap/react": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.0"
  }
}

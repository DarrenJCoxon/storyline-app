# Source — bundled into dist/extension.js, dist/webview/*
src/**
webview/**
# CB-01b: extension/lib/ no longer exists. Runtime modules live in
# packages/runtime/ and are bundled into dist/extension.js by esbuild.
# The .vscodeignore now only whitelists deps that genuinely need to
# ship as real on-disk files — native modules (sharp + @img/*),
# binaries spawned as subprocesses (odd-flow), and assets read from
# disk at runtime (pagedjs polyfill, markdown-it-attrs).
node_modules/**
# Sharp v0.33+ keeps platform-specific native bindings in @img/sharp-*.
# Both the JS wrapper (sharp-<platform>) and the libvips binary
# (sharp-libvips-<platform>) MUST ship — without them sharp's import
# throws and we silently fall back to writing the un-resized model
# output (which can be square instead of the requested 6×9).
!node_modules/sharp/**
!node_modules/@img/**
!node_modules/detect-libc/**
!node_modules/semver/**
!node_modules/color/**
!node_modules/color-convert/**
!node_modules/color-name/**
!node_modules/color-string/**
!node_modules/is-arrayish/**
!node_modules/simple-swizzle/**
# odd-flow durable memory — bundled CLI invoked via spawn(node, …) from
# state/memory.ts. The published odd-flow npm package has a packaging
# bug: its v3/* sub-packages declare deps (sql.js, @noble/ed25519) that
# never get installed transitively, so we install them at the top level
# and whitelist them here too.
!node_modules/odd-flow/**
!node_modules/zod/**
!node_modules/sql.js/**
!node_modules/@noble/**
# pagedjs polyfill — read from disk by packages/runtime/compile/print-pdf.js
# and injected into the Puppeteer page for PDF pagination. Without this
# the print-PDF compile fails with ENOENT on paged.polyfill.min.js.
!node_modules/pagedjs/**
# markdown-it-attrs — required at runtime by markdown-to-html for the
# picture-book `{.bleed .recto}` class syntax parser. esbuild does
# bundle it, but the runtime parser instantiates it via its package
# entry point so the require() resolves at the runtime path too —
# safer to keep it shipping as a real package.
!node_modules/markdown-it-attrs/**

# Tooling and configs
tsconfig.json
esbuild.config.mjs
.vscode/**
.gitignore
.eslintrc*
*.tsbuildinfo
package-lock.json
**/*.map
**/*.test.ts
**/__tests__/**

# Dev backend (not part of the extension)
../backend/**
../packages/**

# Build leftovers
dist/**/*.tsbuildinfo
dist/**/*.d.ts

# odd-flow development artefacts
ruvector.db

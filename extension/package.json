{
  "name": "storyline-extension",
  "displayName": "Storyline",
  "description": "AI-powered planning and writing environment for novelists — Save the Cat structure, multi-provider AI, EPUB/PDF compile.",
  "version": "0.1.7",
  "publisher": "darrenjcoxon",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.storyline/state.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "storyline.startNew",
        "title": "Storyline: Start New Project",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "storyline.openPlanning",
        "title": "Storyline: Open Planning Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "storyline.openEditor",
        "title": "Storyline: Open in Rich Editor"
      },
      {
        "command": "storyline.openToSide",
        "title": "Storyline: Open in Editor to Side"
      },
      {
        "command": "storyline.newChapter",
        "title": "Storyline: New Chapter"
      },
      {
        "command": "storyline.compileEpub",
        "title": "Storyline: Compile to EPUB"
      },
      {
        "command": "storyline.compilePdf",
        "title": "Storyline: Compile to PDF"
      },
      {
        "command": "storyline.openOutputFolder",
        "title": "Storyline: Open Output Folder"
      },
      {
        "command": "storyline.generateCover",
        "title": "Storyline: Generate Cover"
      },
      {
        "command": "storyline.illustrations",
        "title": "Storyline: Illustrations"
      },
      {
        "command": "storyline.manageSubscription",
        "title": "Storyline: Manage Subscription"
      },
      {
        "command": "storyline.changeProvider",
        "title": "Storyline: Change AI Provider"
      },
      {
        "command": "storyline.topUpCredits",
        "title": "Storyline: Top Up Credits"
      },
      {
        "command": "storyline.enterLicenceKey",
        "title": "Storyline: Enter Licence Key"
      },
      {
        "command": "storyline.openLivePreview",
        "title": "Storyline: Open Live Chapter Preview",
        "icon": "$(eye)"
      },
      {
        "command": "storyline.openPreview",
        "title": "Storyline: Open Print Preview",
        "icon": "$(book)"
      },
      {
        "command": "storyline.research",
        "title": "Storyline: Open Research",
        "icon": "$(library)"
      },
      {
        "command": "storyline.doctor",
        "title": "Storyline: Doctor"
      },
      {
        "command": "storyline.generateMasterDoc",
        "title": "Storyline: Generate Master Document"
      },
      {
        "command": "storyline.notes",
        "title": "Storyline: View Manuscript Notes"
      },
      {
        "command": "storyline.snapshotDraft",
        "title": "Storyline: Snapshot Draft"
      },
      {
        "command": "storyline.compareToPlan",
        "title": "Storyline: Compare to Plan"
      },
      {
        "command": "storyline.editBookInfo",
        "title": "Storyline: Edit Book Info"
      },
      {
        "command": "storyline.backupNow",
        "title": "Storyline: Backup Project"
      },
      {
        "command": "storyline.github.connect",
        "title": "Storyline: Connect GitHub"
      },
      {
        "command": "storyline.github.syncNow",
        "title": "Storyline: Sync to GitHub Now"
      },
      {
        "command": "storyline.github.pause",
        "title": "Storyline: Pause GitHub Sync"
      },
      {
        "command": "storyline.github.resume",
        "title": "Storyline: Resume GitHub Sync"
      },
      {
        "command": "storyline.github.openInBrowser",
        "title": "Storyline: Open Project on GitHub"
      },
      {
        "command": "storyline.github.disconnect",
        "title": "Storyline: Disconnect GitHub"
      },
      {
        "command": "storyline.github.openFromGitHub",
        "title": "Storyline: Open Project from GitHub…"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "storyline.research",
          "group": "navigation@97"
        },
        {
          "command": "storyline.openLivePreview",
          "group": "navigation@98"
        },
        {
          "command": "storyline.openPlanning",
          "group": "navigation@99"
        }
      ]
    },
    "keybindings": [
      {
        "command": "storyline.openLivePreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v"
      }
    ],
    "configuration": {
      "title": "Storyline",
      "properties": {
        "storyline.backendUrl": {
          "type": "string",
          "default": "https://api.storyline.my",
          "description": "Backend URL for AI calls. Override to http://localhost:8787 for local development."
        },
        "storyline.aiQuality": {
          "type": "string",
          "enum": [
            "economy",
            "balanced",
            "premium"
          ],
          "default": "balanced",
          "description": "AI critique quality tier. economy = faster/cheaper, balanced = default, premium = deeper critique."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "storyline.welcome",
        "title": "Storyline — Plan and write your book",
        "description": "Set up a new novel or non-fiction project, or open an existing one.",
        "steps": [
          {
            "id": "storyline.start",
            "title": "Start a new project",
            "description": "Scaffold a new Storyline project in this folder — manuscript, planning state, compile config.\n[Start New Project](command:storyline.startNew)",
            "media": {
              "image": "media/icon.svg",
              "altText": "Storyline"
            }
          },
          {
            "id": "storyline.openPlanning",
            "title": "Open the planning chat",
            "description": "Walk through Save the Cat (fiction) or Book DNA (non-fiction) with the AI planning coach.\n[Open Planning Chat](command:storyline.openPlanning)",
            "media": {
              "image": "media/icon.svg",
              "altText": "Planning"
            }
          },
          {
            "id": "storyline.openLivePreview",
            "title": "Preview as paperback / iPad / Kindle",
            "description": "See how your chapter looks on a real device frame as you type.\n[Open Live Preview](command:storyline.openLivePreview)",
            "media": {
              "image": "media/icon.svg",
              "altText": "Preview"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "compile:webview": "vite build --config webview/vite.config.ts",
    "compile:bundle": "node esbuild.config.mjs",
    "build": "npm run compile && npm run compile:webview",
    "build:dist": "npm run typecheck && npm run compile:bundle && npm run compile:webview",
    "watch": "tsc -watch -p ./tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "npm run build:dist && vsce package"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@storyline/core": "file:../packages/core",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.4",
    "isomorphic-git": "^1.37.5",
    "lucide-react": "^1.11.0",
    "markdown-it": "^14.1.0",
    "odd-flow": "^1.2.5",
    "openai": "^4.52.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@tiptap/core": "^2.5.0",
    "@tiptap/extension-horizontal-rule": "^2.5.0",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-table": "^2.5.0",
    "@tiptap/extension-table-cell": "^2.5.0",
    "@tiptap/extension-table-header": "^2.5.0",
    "@tiptap/extension-table-row": "^2.5.0",
    "@tiptap/pm": "^2.5.0",
    "@tiptap/react": "^2.5.0",
    "@tiptap/starter-kit": "^2.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "framer-motion": "^11.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tiptap-markdown": "^0.8.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}

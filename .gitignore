# Dependencies
node_modules/

# Environment (contains API keys — NEVER commit)
.env
.env.local
.env.production
# Cloudflare Wrangler dev secrets (OPENAI_API_KEY, OPENROUTER_API_KEY)
.dev.vars
**/.dev.vars
.wrangler/
**/.wrangler/

# VSIX build output (rebuilt locally; bulky native sharp bindings inside)
*.vsix
extension/dist/
extension/storyline-extension-*.vsix

# Worker bundle (rebuilt by wrangler deploy or local esbuild for dashboard uploads)
backend/dist/

# Generated from docs/TERMS.md + docs/PRIVACY.md by build:legal
backend/src/legal-content.ts

# Generated output (root-level only — lib/output/ is source code)
/output/

# Sync-lib generated copies (lib/compile/fonts is canonical and tracked;
# extension/resources/fonts/ is a build-time copy created by sync-lib).
extension/resources/fonts/

# Test fixture outputs (regenerated by `npm test`)
tests/fixtures/*/output/

# IDE
.vscode/
.idea/
# But DO track the extension's launch config (used for F5 dev of vscode-extension/)
!vscode-extension/.vscode/
!vscode-extension/.vscode/**

# OS
.DS_Store
Thumbs.db

# State (per-project, don't commit)
.novel-writer/

# Local AI tooling (not part of the project)
.claude/
.swarm/
.playwright-mcp/
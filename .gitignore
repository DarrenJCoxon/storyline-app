# Dependencies
node_modules/

# Environment (contains API keys — NEVER commit)
.env
.env.local
.env.production
# Cloudflare Wrangler dev secrets (OPENAI_API_KEY, OPENROUTER_API_KEY)
.dev.vars
**/.dev.vars
.wrangler/
**/.wrangler/

# VSIX build output (rebuilt locally; bulky native sharp bindings inside)
*.vsix

# OpenRouter configuration
# Get your API key from https://openrouter.ai/keys
# Free models available: google/gemini-2.0-flash-thinking-exp:free, anthropic/claude-3.5-haiku, etc.

OPENROUTER_API_KEY=your_api_key_here

# Model selection — adjust based on needs and budget
# Recommended free/tiered models:
#   google/gemini-2.0-flash-thinking-exp:free (fast, good for critique)
#   anthropic/claude-3.5-haiku:free (quality balance)
#   deepseek/deepseek-r1:free (reasoning model)
OPENROUTER_MODEL=google/gemini-2.0-flash-thinking-exp:free